# ============================================================================
# CONFIGURAÇÃO DO BANCO DE DADOS - SQL Server
# ============================================================================

# Credenciais do SQL Server
user_db=sa
pass_db=seu_password
host_db=localhost,1433
db_name=webhookservice

# Alternativa: Se preferir usar DATABASE_URL diretamente (descomente se quiser)
# DATABASE_URL=mssql+pyodbc://sa:seu_password@localhost,1433/webhookservice?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# ============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ============================================================================
FLASK_ENV=development
FLASK_DEBUG=1